      "parameters": {
        "jsCode": "// Prepare update data\nconst reminderId = $('Parse & Validate Request').item.json.reminderId;\nconst updateData = $('Parse & Validate Request').item.json.body;\nconst allReminders = $input.all();\n\nconst found = allReminders.filter(item => String(item.json.reminderId) === String(reminderId));\n\nif (found.length === 0) {\n  return {\n    success: false,\n    notFound: true,\n    error: `Reminder ${reminderId} not found`\n  };\n}\n\nconst existing = found[0].json;\n\n// Merge updates with existing data\nreturn {\n  success: true,\n  notFound: false,\n  reminderId: existing.reminderId,\n  taskTitle: updateData.title || existing.taskTitle,\n  taskDescription: updateData.description || existing.taskDescription,\n  category: updateData.category || existing.category,\n  priority: updateData.priority || existing.priority,\n  eventTime: updateData.eventTime || existing.eventTime,\n  reminderTime: existing.reminderTime,\n  offsetMinutes: existing.offsetMinutes,\n  chatId: existing.chatId,\n  calendarEventId: existing.calendarEventId,\n  sent: existing.sent,\n  createdAt: existing.createdAt\n};"
