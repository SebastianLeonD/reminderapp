    {
      "parameters": {
        "jsCode": "// Validate API Key\nconst apiKey = $input.item.json.headers['x-api-key'] || $input.item.json.query?.apiKey;\nconst VALID_API_KEY = 'YOUR_SECRET_API_KEY_HERE'; // Change this!\n\nif (!apiKey || apiKey !== VALID_API_KEY) {\n  return {\n    authorized: false,\n    error: 'Unauthorized: Invalid or missing API key'\n  };\n}\n\n// Parse request details\nconst method = $input.item.json.method || 'GET';\nconst path = $input.item.json.path || '';\nconst query = $input.item.json.query || {};\nconst body = $input.item.json.body || {};\n\n// Extract reminder ID from path if present (e.g., /api/reminders/123)\nconst pathParts = path.split('/').filter(p => p);\nlet reminderId = null;\nlet action = null;\n\nif (pathParts.length >= 3) {\n  reminderId = pathParts[2];\n}\nif (pathParts.length >= 4) {\n  action = pathParts[3]; // e.g., 'complete'\n}\n\n// Determine operation\nlet operation = 'list';\nif (method === 'GET' && !reminderId) {\n  operation = 'list';\n} else if (method === 'GET' && reminderId) {\n  operation = 'get';\n} else if (method === 'PUT' && reminderId) {\n  operation = 'update';\n} else if (method === 'DELETE' && reminderId) {\n  operation = 'delete';\n} else if (method === 'POST' && reminderId && action === 'complete') {\n  operation = 'complete';\n}\n\nreturn {\n  authorized: true,\n  operation,\n  reminderId,\n  method,\n  query,\n  body,\n  filters: {\n    category: query.category || null,\n    priority: query.priority || null,\n    date: query.date || null,\n    upcoming: query.upcoming === 'true',\n    completed: query.completed || null\n  }\n};"
      },
