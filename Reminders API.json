      "parameters": {
        "jsCode": "// Find specific reminder by ID\nconst reminderId = $('Parse & Validate Request').item.json.reminderId;\nconst allReminders = $input.all();\n\nconst found = allReminders.filter(item => String(item.json.reminderId) === String(reminderId));\n\nif (found.length === 0) {\n  return {\n    success: false,\n    error: `Reminder ${reminderId} not found`\n  };\n}\n\nconst r = found[0].json;\nreturn {\n  success: true,\n  reminder: {\n    id: r.reminderId,\n    calendarEventId: r.calendarEventId,\n    title: r.taskTitle,\n    description: r.taskDescription,\n    category: r.category || 'personal',\n    priority: r.priority || 'medium',\n    eventTime: r.eventTime,\n    reminderTime: r.reminderTime,\n    offsetMinutes: parseInt(r.offsetMinutes) || 0,\n    sent: r.sent === 'true' || r.sent === true,\n    createdAt: r.createdAt\n  }\n};"
      },
