    {
      "parameters": {
        "jsCode": "// Filter and format reminders for API response\nconst filters = $('Parse & Validate Request').item.json.filters;\nconst allReminders = $input.all();\n\nconst now = new Date();\nconst todayStart = new Date(now.getFullYear(), now.getMonth(), now.getDate());\nconst todayEnd = new Date(todayStart);\ntodayEnd.setDate(todayEnd.getDate() + 1);\n\n// Group by calendarEventId to dedupe (multiple reminders per event)\nconst grouped = {};\nallReminders.forEach(item => {\n  const r = item.json;\n  const key = r.calendarEventId || r.reminderId;\n  \n  if (!grouped[key]) {\n    grouped[key] = {\n      id: r.reminderId,\n      calendarEventId: r.calendarEventId,\n      title: r.taskTitle,\n      description: r.taskDescription,\n      category: r.category || 'personal',\n      priority: r.priority || 'medium',\n      eventTime: r.eventTime,\n      sent: r.sent === 'true' || r.sent === true,\n      createdAt: r.createdAt,\n      reminderTimes: []\n    };\n  }\n  grouped[key].reminderTimes.push({\n    reminderId: r.reminderId,\n    reminderTime: r.reminderTime,\n    offsetMinutes: parseInt(r.offsetMinutes) || 0\n  });\n});\n\nlet reminders = Object.values(grouped);\n\n// Apply filters\nif (filters.category) {\n  reminders = reminders.filter(r => r.category === filters.category);\n}\n\nif (filters.priority) {\n  reminders = reminders.filter(r => r.priority === filters.priority);\n}\n\nif (filters.completed === 'true') {\n  reminders = reminders.filter(r => r.sent === true);\n} else if (filters.completed === 'false') {\n  reminders = reminders.filter(r => r.sent === false);\n}\n\nif (filters.upcoming) {\n  reminders = reminders.filter(r => {\n    const eventTime = new Date(r.eventTime);\n    return eventTime >= now;\n  });\n}\n\nif (filters.date === 'today') {\n  reminders = reminders.filter(r => {\n    const eventTime = new Date(r.eventTime);\n    return eventTime >= todayStart && eventTime < todayEnd;\n  });\n}\n\n// Sort by eventTime\nreminders.sort((a, b) => new Date(a.eventTime) - new Date(b.eventTime));\n\nreturn {\n  success: true,\n  count: reminders.length,\n  reminders\n};"
      },
